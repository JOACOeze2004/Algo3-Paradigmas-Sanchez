Object subclass: #AlgoPrediccionCripto	instanceVariableNames: 'criterio tokens'	classVariableNames: ''	package: 'TP1'!!AlgoPrediccionCripto methodsFor: 'initialization' stamp: 'Anonymous 4/13/2025 11:05'!initialize tokens := OrderedCollection new.! !!AlgoPrediccionCripto methodsFor: 'accessing' stamp: 'Anonymous 4/11/2025 19:36'!criterio: unCriterio	criterio := CriterioPrediccion crearSegun: unCriterio .! !!AlgoPrediccionCripto methodsFor: 'accessing' stamp: 'Anonymous 4/11/2025 18:45'!criterio	^ criterio.! !!AlgoPrediccionCripto methodsFor: 'not defined category' stamp: 'FirstnameLastname 5/5/2025 17:34'!prediccionDe: unNombre conRecomendador: unRecomendador ^ (self buscarTokenSegun: unNombre conRecomendador: unRecomendador) crearPrediccion.! !!AlgoPrediccionCripto methodsFor: 'not defined category' stamp: 'FirstnameLastname 5/5/2025 17:32'!buscarTokenSegun: unNombre conRecomendador: unRecomendador^ tokens detect: [ :token | token coincideConNombre: unNombre yRecomendador:unRecomendador ].! !!AlgoPrediccionCripto methodsFor: 'not defined category' stamp: 'FirstnameLastname 5/6/2025 09:10'!registrarTokenConNombre: unToken ConValorActual: unValor ConRecomendador: unRecomendador yEdad: unaEdad yPatrimonio: unPatrimonio deNacionalidad: unaNacionalidad yColorDePelo: unColorDePelo |token |token := InfoToken crearCon: unToken  valor:unValor  recomendador: unRecomendador edad:unaEdad  patrimonio: unPatrimonio nacionalidad: unaNacionalidad colorDePelo: unColorDePelo.tokens add: token.! !!AlgoPrediccionCripto methodsFor: 'not defined category' stamp: 'FirstnameLastname 5/5/2025 11:21'!obtenerDivulgadorSegunCriterio|mejorToken|mejorToken := tokens first.tokens do:[:token | mejorToken := criterio mejorEntre: mejorToken  yOtro: token.].^ mejorToken nombreRecomendador.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!AlgoPrediccionCripto class	instanceVariableNames: 'criterio'!!AlgoPrediccionCripto class methodsFor: 'not defined category' stamp: 'Anonymous 4/16/2025 23:40'!conCriterio: unCriterio| instancia |instancia := self new.instancia criterio: unCriterio.^ instancia! !Object subclass: #ColorPelo	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!ColorPelo methodsFor: 'not defined category' stamp: 'FirstnameLastname 7/18/2025 10:33'!calcularSegunColorPeloDe: unaEdad con: unPatrimonioself subclassResponsibility."Extra Post correccion: no es muy Open-close pero antes pasaba el recomendador y le pedi sus atributos lo que violaba Tell dont ask, hay mejores formas de hacerlo (como un strategy un poco mas elavorado), pero no tengo tantas ganas de hacerlo."! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!ColorPelo class	instanceVariableNames: ''!!ColorPelo class methodsFor: 'not defined category' stamp: 'FirstnameLastname 5/1/2025 11:01'!crearSegun: unString	self = ColorPelo ifFalse: [		CrearColorDePeloInvalidoError signal].	unString = 'Colorado' ifTrue: [ ^ Colorado new ].	unString = 'Rubio' ifTrue: [ ^ Rubio new ].	unString = 'Morocho' ifTrue: [ ^ Morocho new ].	ColorPeloDesconocidoError signal.! !Error subclass: #ColorPeloDesconocidoError	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!ColorPelo subclass: #Colorado	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!Colorado methodsFor: 'not defined category' stamp: 'FirstnameLastname 7/18/2025 10:20'!calcularSegunColorPeloDe: unaEdad con: unPatrimonio^ ((unPatrimonio / 10) + ( unaEdad  * 3)).! !Error subclass: #CrearColorDePeloInvalidoError	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!Error subclass: #CrearCriterioInvalidoError	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!Error subclass: #CrearNacionalidadInvalidaError	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!Object subclass: #CriterioPrediccion	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!CriterioPrediccion methodsFor: 'not defined category' stamp: 'Anonymous 4/10/2025 10:44'!mejorEntre: untoken yOtro: otroToeknself subclassResponsibility.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!CriterioPrediccion class	instanceVariableNames: ''!!CriterioPrediccion class methodsFor: 'not defined category' stamp: 'FirstnameLastname 5/1/2025 11:26'!crearSegun: unString	self = CriterioPrediccion ifFalse: [		CrearCriterioInvalidoError signal.].    unString = 'Maximo' ifTrue: [ ^ Maximo new ].	unString = 'Minimo' ifTrue: [ ^ Minimo  new ].	CriterioPrediccionDesconocidoError signal.! !Error subclass: #CriterioPrediccionDesconocidoError	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!Error subclass: #EdadMenor18Error	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!Object subclass: #InfoToken	instanceVariableNames: 'nombre valor recomendador'	classVariableNames: ''	package: 'TP1'!!InfoToken methodsFor: 'accessing' stamp: 'Anonymous 4/8/2025 16:20'!nombre^ nombre.! !!InfoToken methodsFor: 'not defined category' stamp: 'FirstnameLastname 5/6/2025 10:25'!coincideConNombre: unNombre yRecomendador: unRecomendador^ self nombre = unNombre and: [ recomendador tieneNombre: unRecomendador ].! !!InfoToken methodsFor: 'not defined category' stamp: 'Anonymous 4/9/2025 12:03'!recomendador^ recomendador .! !!InfoToken methodsFor: 'not defined category' stamp: 'FirstnameLastname 5/6/2025 09:34'!inicializarTokenCon: unNombre valor: unValor recomendador: unRecomendador    nombre := unNombre.    valor := unValor.    recomendador :=  unRecomendador.! !!InfoToken methodsFor: 'not defined category' stamp: 'FirstnameLastname 5/5/2025 15:01'!crearPrediccion    ^ Prediccion con: (self calcularPrediccion).! !!InfoToken methodsFor: 'not defined category' stamp: 'FirstnameLastname 5/6/2025 10:22'!calcularPrediccion^ recomendador calcularPrediccionCon: valor.! !!InfoToken methodsFor: 'not defined category' stamp: 'FirstnameLastname 5/1/2025 10:31'!nombreRecomendador   ^ self recomendador nombre.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!InfoToken class	instanceVariableNames: ''!!InfoToken class methodsFor: 'not defined category' stamp: 'FirstnameLastname 5/6/2025 10:22'!crearCon: unNombre valor: unValor recomendador: unRecomendador edad:unaEdad  patrimonio: unPatrimonio nacionalidad: unaNacionalidad colorDePelo: unColorDePelo|nuevoToken criptoBro|	(unValor < 0) ifTrue: [ ValorInvalidoError signal. ].	criptoBro := Recomendador crearConNombre: unRecomendador  edad:unaEdad  patrimonio: unPatrimonio nacionalidad: unaNacionalidad colorDePelo: unColorDePelo.	nuevoToken := self new.	nuevoToken inicializarTokenCon: unNombre  valor: unValor recomendador: criptoBro.	^ nuevoToken.! !CriterioPrediccion subclass: #Maximo	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!Maximo methodsFor: 'not defined category' stamp: 'Anonymous 4/10/2025 11:35'!mejorEntre: unToken yOtro: otroToken^(unToken calcularPrediccion > otroToken calcularPrediccion ) ifTrue: [ unToken ] ifFalse: [ otroToken ].! !CriterioPrediccion subclass: #Minimo	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!Minimo methodsFor: 'not defined category' stamp: 'Anonymous 4/10/2025 11:35'!mejorEntre: unToken yOtro: otroToken^(unToken calcularPrediccion < otroToken calcularPrediccion ) ifTrue: [ unToken ] ifFalse: [otroToken  ].! !ColorPelo subclass: #Morocho	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!Morocho methodsFor: 'not defined category' stamp: 'FirstnameLastname 7/18/2025 10:20'!calcularSegunColorPeloDe: unaEdad con: unPatrimonio^ ((unPatrimonio  * unaEdad) / 10000000).! !Object subclass: #Nacionalidad	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!Nacionalidad methodsFor: 'not defined category' stamp: 'Anonymous 4/9/2025 16:13'!calcularSegunNacionalidad: unValorself subclassResponsibility.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Nacionalidad class	instanceVariableNames: ''!!Nacionalidad class methodsFor: 'not defined category' stamp: 'FirstnameLastname 5/1/2025 13:07'!crearSegun: unString	self = Nacionalidad ifFalse: [		CrearNacionalidadInvalidaError signal. ].	(unString isEmptyOrNil) ifTrue: [ NacionalidadDesconocidoError signal ].   unString = 'Argentina' ifTrue: [ ^ Argentina  new ].    ^ Extranjera new.! !Nacionalidad subclass: #Argentina	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!Argentina methodsFor: 'not defined category' stamp: 'Anonymous 4/9/2025 16:14'!calcularSegunNacionalidad: unValor^ unValor * 0.75.! !Nacionalidad subclass: #Extranjera	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!Extranjera methodsFor: 'not defined category' stamp: 'Anonymous 4/9/2025 16:15'!calcularSegunNacionalidad: unValor^ unValor * 1.10.! !Error subclass: #NacionalidadDesconocidoError	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!Error subclass: #NombreRecomendadorInvalidoError	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!Error subclass: #PatrimonioMenorA0Error	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!Object subclass: #Prediccion	instanceVariableNames: 'valor'	classVariableNames: ''	package: 'TP1'!!Prediccion methodsFor: 'accessing' stamp: 'Anonymous 4/6/2025 18:44'!valor^ valor.! !!Prediccion methodsFor: 'accessing' stamp: 'Anonymous 4/12/2025 19:18'!valor: unValor    valor := unValor.! !!Prediccion methodsFor: 'not defined category' stamp: 'Anonymous 4/8/2025 17:34'!compararCon: unValor precision: unaPrecision    ^ (valor - unValor) abs < unaPrecision.! !!Prediccion methodsFor: 'not defined category' stamp: 'Anonymous 4/12/2025 19:48'!compararPrediccionEnPesosCon: unValorEnPesos precision: unaPrecision^ (self valorEnPesos - unValorEnPesos) abs < unaPrecision.! !!Prediccion methodsFor: 'not defined category' stamp: 'Anonymous 4/12/2025 17:41'!valorEnPesos   ^ valor*1200.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Prediccion class	instanceVariableNames: ''!!Prediccion class methodsFor: 'not defined category' stamp: 'Anonymous 4/12/2025 18:35'!con: unValor^ self new valor: unValor.! !Object subclass: #Recomendador	instanceVariableNames: 'nombre edad patrimonio nacionalidad colorDePelo'	classVariableNames: ''	package: 'TP1'!!Recomendador methodsFor: 'as yet unclassified' stamp: 'FirstnameLastname 5/6/2025 09:38'!inicializarConNombre: unNombre edad: unaEdad patrimonio: unPatrimonio nacionalidad: unaNacionalidad colorDePelo: unColor    nombre := unNombre.    edad := unaEdad.    patrimonio := unPatrimonio.    nacionalidad := Nacionalidad crearSegun: unaNacionalidad.    colorDePelo := ColorPelo crearSegun: unColor.! !!Recomendador methodsFor: 'not defined category' stamp: 'FirstnameLastname 7/18/2025 10:28'!calcularPrediccionCon: unValor^ (nacionalidad calcularSegunNacionalidad: (colorDePelo calcularSegunColorPeloDe: edad  con: patrimonio )) + unValor.! !!Recomendador methodsFor: 'not defined category' stamp: 'FirstnameLastname 5/6/2025 10:25'!tieneNombre: unNombre ^ nombre = unNombre.! !!Recomendador methodsFor: 'accessing' stamp: 'Anonymous 4/9/2025 12:37'!nombre^ nombre.! !!Recomendador methodsFor: 'accessing' stamp: 'Anonymous 4/9/2025 16:05'!patrimonio ^ patrimonio.! !!Recomendador methodsFor: 'accessing' stamp: 'Anonymous 4/10/2025 18:48'!colorDePelo ^ colorDePelo.! !!Recomendador methodsFor: 'accessing' stamp: 'Anonymous 4/9/2025 16:06'!edad ^ edad.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Recomendador class	instanceVariableNames: ''!!Recomendador class methodsFor: 'not defined category' stamp: 'FirstnameLastname 5/6/2025 10:14'!crearConNombre: unNombre edad: unaEdad patrimonio: unPatrimonio nacionalidad: unaNacionalidad colorDePelo: unColor| nuevoRecomendador |		(unNombre isEmptyOrNil) ifTrue: [ NombreRecomendadorInvalidoError signal. ].	(unaEdad  < 18) ifTrue: [ EdadMenor18Error signal. ].	(unPatrimonio  < 0) ifTrue: [ PatrimonioMenorA0Error signal. ].   nuevoRecomendador := self new.		nuevoRecomendador inicializarConNombre: unNombre  edad: unaEdad patrimonio: unPatrimonio nacionalidad: unaNacionalidad colorDePelo: unColor.   ^ nuevoRecomendador.! !ColorPelo subclass: #Rubio	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!Rubio methodsFor: 'not defined category' stamp: 'FirstnameLastname 7/18/2025 10:20'!calcularSegunColorPeloDe: unaEdad con: unPatrimonio^ (unPatrimonio  - ( unaEdad  *175000)).! !Error subclass: #ValorInvalidoError	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!