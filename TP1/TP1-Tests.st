TestCase subclass: #AlgoPrediccionCriptoTest	instanceVariableNames: 'precision'	classVariableNames: ''	package: 'TP1-Tests'!!AlgoPrediccionCriptoTest methodsFor: 'tests' stamp: 'Joaquin 4/1/2025 23:05'!test03UnRecomendadorMorochoConCiertaEdadyPatrimonioPuedePredecirUnAumentoDeCiertaCriptoDeCiertoValor	| prediccionEsperada prediccionObtenida algoPrediccionCripto  |		"Arrange"		prediccionEsperada := 2865.6.	algoPrediccionCripto  := AlgoPrediccionCripto conCriterio: 'Maximo'.		"El recomendador es de un pais extranjero por lo que tiene gran veracidad. Su valor equivale al 110%."	"Debido a que es morocho, la cripto puede aumentar su edad multiplicado por su patrimonio dividido 10000000"	algoPrediccionCripto registrarTokenConNombre: '$X AE A-XII' ConValorActual: 1000 ConRecomendador: 'Elon' yEdad: 53 yPatrimonio: 320000000 deNacionalidad: 'Sudafrica' yColorDePelo: 'Morocho'.		"Act"		prediccionObtenida := algoPrediccionCripto prediccionDe: '$X AE A-XII' conRecomendador: 'Elon'.		"Assert"	self assert: (prediccionObtenida compararCon: prediccionEsperada precision: precision )! !!AlgoPrediccionCriptoTest methodsFor: 'tests' stamp: 'Joaquin 4/1/2025 22:54'!test06EntreVariosRecomendadoresDetectaAlQuePrediceUnMayorValor	| divulgadorMayorGananciaEsperado divulgadorMayorGananciaObtenido algoPrediccionCripto  |		"Arrange"		divulgadorMayorGananciaEsperado := 'Donald'.	algoPrediccionCripto  := AlgoPrediccionCripto conCriterio: 'Maximo'.		algoPrediccionCripto registrarTokenConNombre: '$MASIVO' ConValorActual: 10 ConRecomendador: 'Matias' yEdad: 21 yPatrimonio: 50000 deNacionalidad: 'Argentina' yColorDePelo: 'Colorado'.		algoPrediccionCripto registrarTokenConNombre: '$MECHANICUS' ConValorActual: 1000 ConRecomendador: 'Elon' yEdad: 53 yPatrimonio: 320000000 deNacionalidad: 'Sudafrica' yColorDePelo: 'Morocho'.		algoPrediccionCripto registrarTokenConNombre: '$BITCOIN' ConValorActual: 1000 ConRecomendador: 'Donald' yEdad: 78 yPatrimonio: 300000000 deNacionalidad: 'Estados Unidos' yColorDePelo: 'Rubio'.		algoPrediccionCripto registrarTokenConNombre: '$LIBRA' ConValorActual: 1 ConRecomendador: 'Javier' yEdad: 54 yPatrimonio: 10000000 deNacionalidad: 'Argentina' yColorDePelo: 'Morocho'.		"Act"		divulgadorMayorGananciaObtenido := algoPrediccionCripto obtenerDivulgadorSegunCriterio.		"Assert"	self assert: divulgadorMayorGananciaEsperado equals: divulgadorMayorGananciaObtenido! !!AlgoPrediccionCriptoTest methodsFor: 'tests' stamp: 'Joaquin 4/1/2025 23:05'!test07UnRecomendadorConCiertoColorDePeloPatrimonioYEdadPuedePredecirUnAumentoDeCiertaCriptoDeCiertoValorEnPesos	| prediccionEsperadaEnPesos algoPrediccionCripto prediccionObtenida |		"Arrange"		prediccionEsperadaEnPesos := 4568700.	algoPrediccionCripto  := AlgoPrediccionCripto conCriterio: 'Maximo'.		algoPrediccionCripto registrarTokenConNombre: '$MASIVO' ConValorActual: 10 ConRecomendador: 'Matias' yEdad: 21 yPatrimonio: 50000 deNacionalidad: 'Argentina' yColorDePelo: 'Colorado'.		"Act"		prediccionObtenida := algoPrediccionCripto prediccionDe: '$MASIVO' conRecomendador: 'Matias'.			"Assert"	"Prediccion en pesos = Prediccion en dolares × 1200"	self assert: (prediccionObtenida compararPrediccionEnPesosCon: prediccionEsperadaEnPesos  precision: precision )! !!AlgoPrediccionCriptoTest methodsFor: 'tests' stamp: 'FirstnameLastname 4/29/2025 15:59'!test08CreoUnAlgoritmoConCriterioMaximoYMeDevuelveQueElCriterioEsMaximo"De aca para abajo son test que agregue yo para matar mutantes de la clase Algo"| prediccionEsperada prediccionObtenida algoPrediccionCripto |"Arrange"prediccionEsperada := 100.21.algoPrediccionCripto  := AlgoPrediccionCripto new.algoPrediccionCripto criterio: 'Maximo'.	algoPrediccionCripto registrarTokenConNombre: 'TDA' ConValorActual: 100 ConRecomendador: 'Martin' yEdad: 35 yPatrimonio: 80000 deNacionalidad: 'Argentina' yColorDePelo: 'Morocho'.	"Act"prediccionObtenida := algoPrediccionCripto prediccionDe: 'TDA' conRecomendador: 'Martin'."Assert"			self assert: (prediccionObtenida compararCon: prediccionEsperada precision: precision ).		self assert: (algoPrediccionCripto  criterio class ) = Maximo  .		self deny: (algoPrediccionCripto  criterio class) = Minimo .! !!AlgoPrediccionCriptoTest methodsFor: 'tests' stamp: 'Anonymous 4/8/2025 16:47'!test05EntreVariosRecomendadoresDetectoAlQuePrediceUnMenorValor	| divulgadorMenorGananciaEsperado divulgadorMenorGananciaObtenido algoPrediccionCripto  |		"Arrange"		divulgadorMenorGananciaEsperado := 'Javier'.	algoPrediccionCripto  := AlgoPrediccionCripto conCriterio: 'Minimo'.		algoPrediccionCripto registrarTokenConNombre: '$MASIVO' ConValorActual: 10 ConRecomendador: 'Matias' yEdad: 21 yPatrimonio: 50000 deNacionalidad: 'Argentina' yColorDePelo: 'Colorado'.		algoPrediccionCripto registrarTokenConNombre: '$BITCOIN' ConValorActual: 1000 ConRecomendador: 'Elon' yEdad: 53 yPatrimonio: 320000000 deNacionalidad: 'Sudafrica' yColorDePelo: 'Morocho'.		algoPrediccionCripto registrarTokenConNombre: '$BITCOIN' ConValorActual: 1000 ConRecomendador: 'Donald' yEdad: 78 yPatrimonio: 300000000 deNacionalidad: 'Estados Unidos' yColorDePelo: 'Rubio'.		algoPrediccionCripto registrarTokenConNombre: '$LIBRA' ConValorActual: 1 ConRecomendador: 'Javier' yEdad: 54 yPatrimonio: 10000000 deNacionalidad: 'Argentina' yColorDePelo: 'Morocho'.	"Act"		divulgadorMenorGananciaObtenido := algoPrediccionCripto obtenerDivulgadorSegunCriterio.		"Assert"	self assert: divulgadorMenorGananciaEsperado equals: divulgadorMenorGananciaObtenido! !!AlgoPrediccionCriptoTest methodsFor: 'tests' stamp: 'Anonymous 4/9/2025 18:37'!test01UnRecomendadorArgentinoConCiertoColorDePeloPatrimonioYEdadPuedePredecirUnAumentoDeCiertaCriptoDeCiertoValor		| prediccionEsperada prediccionObtenida algoPrediccionCripto  |		"Arrange"		prediccionEsperada := 3807.25.	algoPrediccionCripto  := AlgoPrediccionCripto conCriterio: 'Maximo'.		"El recomendador es de Argentina, por lo 